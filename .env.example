# Copiá este archivo como .env y completá los valores reales.
# El .env está en .gitignore — nunca se sube a GitHub.

ANTHROPIC_API_KEY=sk-ant-...

# Alpaca (lo configuramos en el Paso 9)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Base de datos (lo configuramos en el Paso 5/9)
DATABASE_URL=postgresql://...

# Notificaciones (opcional por ahora)
ALERT_EMAIL=

# ── Killswitch / habilitación del sistema ──
# El orchestrator solo corre si SYSTEM_ENABLED == "true".
# Mantenelo en "false" hasta el día del lanzamiento.
SYSTEM_ENABLED=false

# ── Slack (notif de drafts sociales al celu) ──
# Obtenelo en: Slack → Apps → Incoming Webhooks → Add to Workspace.
# Te dan una URL del estilo https://hooks.slack.com/services/T.../B.../...
# Si la dejás vacía, el pipeline corre igual y solo loggea warning.
SLACK_WEBHOOK_URL=

# ── Slack Listener (engagement_reply via mensaje en canal) ──
# El listener postea engagement_reply cuando vos mandás un mensaje en
# un canal específico. NO requiere endpoint público ni tunnel.
# Setup: docs/SLACK_BOT_SETUP.md.
#
# SLACK_BOT_TOKEN: el `xoxb-...` (Bot User OAuth Token) de tu Slack app.
# SLACK_LISTEN_CHANNEL: nombre del canal sin #, ej "indigo-replies".
SLACK_BOT_TOKEN=
SLACK_LISTEN_CHANNEL=
SLACK_POLL_INTERVAL=5

# Slack Bot — slash command alternativo (`/reply` con endpoint HTTP). Solo
# si querés correr `py -m pipeline.social.slack_bot` (más complejo, requiere
# tunnel/Cloudflare). El listener de arriba alcanza para 99% de los casos.
SLACK_SIGNING_SECRET=
SLACK_BOT_PORT=8001
